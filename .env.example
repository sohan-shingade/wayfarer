# Copy to .env and fill. NOTE: do NOT set ANTHROPIC_API_KEY if you want the
# agents to run on your Claude Max/Pro subscription. The runtime strips it from
# the child process anyway, but keeping it out of your shell avoids confusion.

# SerpApi powers BOTH hotels (google_hotels) and, optionally, flights
# (google_flights). One key, free tier ~250 searches/mo. Without it, lodging
# falls back to a labeled flat-rate estimate.
SERPAPI_API_KEY=
